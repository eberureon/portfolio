---
import Sidebar from '../../components/en/Sidebar.astro';
import Layout from '../../layouts/Layout.astro';
---

<style>
  .container {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    max-width: 1500px;
    margin: auto;
  }

  .content {
    color: #2C3E50;
    padding: 2rem;
  }

  .summary {
    margin-bottom: 3rem;
  }

  .content-section {
    border-left: 4px solid #FF6B35;
    padding-left: 1.5rem;
    margin-bottom: 2rem;

    h3 {
      font-size: 1.25rem;
      margin-top: 0.5rem;
    }

    h3:first-child {
      margin-top: 0;
      line-height: 1;
      margin-bottom: 0.25rem;
    }
  }

  .content-section:last-child {
    margin-bottom: 0;
  }

  h2 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  details {
    margin-top: 0.5rem;

    summary {
      cursor: pointer;
      user-select: none;
    }

    div {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 0.5rem;

      span {
        width: fit-content;
        background-color: #2C3E50;
        border-radius: 0.5rem;
        padding: 0.125rem 0.5rem;
        color: #fff;
        text-align: center;
        font-size: 0.875rem;
      }
    }
  }

  ul {
    padding-inline-start: 2rem;
  }

  /* Large desktops and high-resolution screens (1025px and up) */
  @media (min-width: 1025px) {
    .container {
      /* Desktop: Sidebar + Content */
      grid-template-columns: 1fr 2fr;
      box-shadow: 10px 0 20px -10px rgba(0, 0, 0, 0.1);
    }

    .content {
      padding-left: 5rem;
      padding-right: 5rem;
    }

    .content-section {
      margin-bottom: 3rem;
    }
  }
</style>

