---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro'
---

<style>
  .container {
    display: grid;
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
    max-width: 1500px;
    margin: auto;
  }

  .content {
    color: #203b63;
    padding: 2rem;
  }

  h2 {
    font-size: 2rem;
  }

  /* Large desktops and high-resolution screens (1025px and up) */
  @media (min-width: 1025px) {
    .container {
      /* Desktop: Sidebar + Content */
      grid-template-columns: 1fr 2fr;
      box-shadow: 10px 0 20px -10px rgba(0, 0, 0, 0.1);
    }

    .content {
      padding-left: 7rem;
      padding-right: 7rem;
    }
  }
</style>

<Layout>
  <div class="container">
    <Sidebar />
    <div class="content">
      <h2>Zusammenfassung</h2>
      <p>Ich bin Full-Stack-Entwickler mit Fokus auf Webentwicklung. Aktuell studiere ich berufsbegleitend Informatik (mit Schwerpunkt IT-Sicherheit) an der Friedrich-Alexander-Universität in Erlangen.</p>
    </div>
  </div>
</Layout>
