---
import { Image } from "astro:assets";
import ProfileImage from "../../../assets/profile.jpg";
---

<style>
  @import '../index.css';
</style>

<div class="sidebar">
  <div class="content">
    <div class="language-switcher">
      <a href="/" aria-label="German version">DE</a>
      <span>|</span>
      <a href="/en" class="active" aria-label="English version">EN</a>
    </div>
    <div class="profile-container">
      <Image
        class="profile-image"
        src={ProfileImage}
        alt="Profile picture of Leon Ebel"
        width={250}
        widths={[150, 200, 250, 300]}
        sizes="(max-width: 768px) 150px, (max-width: 1024px) 250px, 200px"
        quality={85}
        fetchpriority="high"
        format="webp"
        decoding="async"
        loading="eager"
        layout="constrained"
      />
    </div>
    <h1>Leon Ebel</h1>
    <strong class="job-title">Software Developer</strong>
    <div>
      <span>Munich |</span>
      <a href="mailto:kontakt@ebelleon.de" aria-label="Send email to Leon Ebel">E-Mail</a>
      <span>|</span>
      <a href="https://www.github.com/eberureon" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile of Leon Ebel (opens in new tab)">GitHub</a>
      <span>|</span>
      <a href="https://www.linkedin.com/in/ebelleon" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile of Leon Ebel (opens in new tab)">LinkedIn</a>
      <!-- <span>| Available immediately</span> -->
    </div>
  </div>

  <div class="content">
    <strong>Technical Expertise</strong>
    <hr />
    <p><b>Programming Languages & Frameworks:</b> JavaScript / TypeScript, React, Next.js, Node.js, Java</p>
    <p><b>Testing:</b> Test-Driven Development (TDD), Jest, Cypress, Playwright</p>
    <p><b>Databases & APIs:</b> SQL, REST, GraphQL, MongoDB, SQLite</p>
    <p><b>DevOps & Infrastructure:</b> Unix, Docker, Google Cloud Platform, AWS</p>
    <p><b>User Interface (UI):</b> CSS, TailwindCSS, Sass, Figma</p>
    <p><b>Development Tools:</b> neovim, VSCode, Git, GitHub Actions</p>
    <p><b>Project Management & Workflows:</b> Scrum, Agile, Confluence, Jira, Linear</p>

  </div>

    <div class="content">
      <strong>Additional Information</strong>
      <hr />
      <p><b>Languages:</b> German (Native), English (Business Fluent)</p>
      <p><b>Interests:</b> Web Development, IT Security, Home Server, Hobby Barista, Handball</p>
    </div>
</div>
