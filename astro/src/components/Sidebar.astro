---
import { Image } from 'astro:assets';
import ProfileImage from '../assets/profile.jpg';
---

<style>
  * {
    color: #fff;
  }

  .sidebar {
    background-color: #2C3E50;
  }

  .content {
    padding: 2rem;
  }

  .content:first-child {
    padding-top: 2rem;
  }

  h1 {
    color: #FF6B35;
    font-size: 1.75rem;
    text-transform: uppercase;
  }

  .job-title {
    text-transform: uppercase;
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
    font-weight: 500;
  }

  .profile-image {
    border-radius: 100%;
    margin: 0 auto 1rem;
    transition: border-radius 0.3s ease-in-out;

    &:hover {
      border-radius: 0.5rem;
    }
  }

  strong {
    display: inline-block;
    font-size: 1.5rem;
  }

  hr {
    margin: 0.5rem auto;
  }

  p {
    margin-bottom: 1rem;
  }

  /* Large desktops and high-resolution screens (1025px and up) */
  @media (min-width: 1025px) {
    .sidebar {
      min-height: 100lvh;
    }

    .content {
      padding-top: 4rem;
      padding-bottom: 4rem;
    }

    .content:last-child {
      padding-bottom: 0;
    }
  }
</style>

<div class="sidebar">
  <div class="content">
    <Image
      class="profile-image"
      src={ProfileImage}
      alt="Bild von Leon Ebel"
      width={200}
      height={200}
      widths={[100, 150, 200]}
      sizes="(max-width: 768px) 100px, (max-width: 1024px) 150px, 200px"
      quality={80}
      format="webp"
      loading="lazy"
    />
    <h1>Leon Ebel</h1>
    <strong class="job-title">Software Developer</strong>
    <div>
      <span>München |</span>
      <a href="mailto:kontakt@ebelleon.de" aria-label="E-Mail an Leon Ebel senden">E-Mail</a>
      <span>|</span>
      <a href="https://www.github.com/eberureon" target="_blank" rel="noopener noreferrer" aria-label="GitHub Profil von Leon Ebel (öffnet in neuem Tab)">Github</a>
      <span>|</span>
      <a href="https://www.linkedin.com/in/ebelleon" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn Profil von Leon Ebel (öffnet in neuem Tab)">LinkedIn</a>
      <span>| Verfügbar ab sofort</span>
    </div>
  </div>

  <div class="content">
    <strong>Technische Expertise</strong>
    <hr />
    <p><b>Programmiersprachen & Framekworks:</b> JavaScript / TypeScript, React, Next.js, Node.js, Java</p>
    <p><b>Testing:</b> Test-Driven Development (TDD), Jest, Cypress, Playwright</p>
    <p><b>Datenbanken & APIs:</b> SQL, REST, GraphQL, MongoDB, SQLite</p>
    <p><b>DevOps & Infrastructure:</b> Docker, AWS, GCP, Unix</p>
    <p><b>User Interface (UI):</b> CSS, TailwindCSS, Sass, Figma</p>
    <p><b>Entwicklungs Tools:</b> neovim, VSCode, Git, Github Actions</p>
    <p><b>Projektmanagement & Workflows:</b> Scrum, Agile, Confluence, Jira, Linear</p>

  </div>

    <div class="content">
      <strong>Weitere Informationen</strong>
      <hr />
      <p><b>Sprachen:</b> Deutsch (Muttersprache), Englisch (verhandlungssicher)</p>
      <p><b>Interessen:</b> Web-Entwicklung, IT-Sicherheit, Homeserver, Handball</p>
    </div>
</div>
